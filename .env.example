# Backblaze B2 (required) — Standard #3 env names
B2_ENDPOINT=your_b2_endpoint
B2_APPLICATION_KEY_ID=your_key_id
B2_APPLICATION_KEY=your_application_key
B2_BUCKET_NAME=your-bucket-name
B2_REGION=your_b2_region
# B2_PUBLIC_URL=                          # optional — base URL for public objects

# OpenAI — powers BOTH script generation (LLM) and audio synthesis (TTS) (required)
OPENAI_API_KEY=your_openai_api_key
LLM_MODEL=gpt-4o-mini
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE_HOST_A=alloy
TTS_VOICE_HOST_B=verse
HOST_A_NAME=Alex
HOST_B_NAME=Sam

# Example of what filled-in B2 values look like (fake — for visual reference only):
# B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
# B2_APPLICATION_KEY_ID=<your-key-id-from-the-B2-console>
# B2_APPLICATION_KEY=<your-application-key-shown-once-in-the-B2-console>
# B2_BUCKET_NAME=my-app-uploads
# B2_REGION=us-west-004
